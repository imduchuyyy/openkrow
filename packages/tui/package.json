{
  "name": "@openkrow/tui",
  "version": "0.1.0",
  "description": "Terminal UI library with differential rendering",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "strip-ansi": "^7.1.0",
    "wrap-ansi": "^9.0.0",
    "cli-spinners": "^3.2.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
