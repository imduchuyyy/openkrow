{
  "name": "@openkrow/pods",
  "version": "0.1.0",
  "description": "CLI for managing vLLM deployments on GPU pods",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "krow-pods": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
